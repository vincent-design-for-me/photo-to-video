# LLM for per-image Nano Banana prompt generation (OpenAI-compatible)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-5.4

# Nano Banana / Gemini image generation
# IMAGE_* names match the third-party provider config used in the older project.
IMAGE_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=gemini-3-pro-image-preview
IMAGE_API_FORMAT=gemini-native

# GEMINI_* aliases are also supported. Leave blank when IMAGE_* is set.
GEMINI_API_KEY=
GEMINI_API_BASE_URL=
GEMINI_IMAGE_MODEL=
GEMINI_API_FORMAT=

# Kling-compatible video API
# Use either KLING_API_KEY, or official-style KLING_ACCESS_KEY + KLING_SECRET_KEY.
KLING_PROVIDER=skill
KLING_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api-beijing.klingai.com
KLING_MODEL=video-3.0-omni
KLING_MODE=professional
KLING_DURATION_SECONDS=3
KLING_RESOLUTION=1080p
KLING_NATIVE_AUDIO=true
KLING_AUDIO_SYNC=true
KLING_POLL_ATTEMPTS=120
KLING_POLL_INTERVAL_MS=5000

# Kling Skill mode. Confirm these values in the Kling API Skill page.
KLING_SKILL_EFFECT_SCENE=
KLING_SKILL_CREATE_PATH=/v1/videos/effects
KLING_SKILL_STATUS_PATH=/v1/videos/{task_id}
# Optional JSON body template. Supported placeholders:
# {{effectScene}}, {{firstFrameUrl}}, {{lastFrameUrl}}, {{prompt}}, {{clipSeconds}}, {{aspectRatio}}
KLING_SKILL_REQUEST_TEMPLATE=

# Kling providers usually require public image URLs.
# Replace lib/providers/kling.ts uploadFrameForKling with your storage uploader,
# or set this when files are already uploaded to a public bucket/CDN.
PUBLIC_ASSET_BASE_URL=
